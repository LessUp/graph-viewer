# Kroki 渲染服务配置
# 默认的 Kroki 服务 URL
KROKI_BASE_URL=https://kroki.io

# 安全配置：是否允许客户端指定任意 Kroki URL
# 设置为 true 会允许 SSRF 攻击风险，仅建议在开发/测试环境使用
# 默认为 false
KROKI_ALLOW_CLIENT_BASE_URL=false

# 安全配置：允许的客户端 Kroki URL 白名单（逗号分隔）
# 例如：https://kroki.io,https://kroki.example.com
# 如果 KROKI_ALLOW_CLIENT_BASE_URL=false，只有此列表中的 URL 会被允许
# 默认为空，表示只允许 KROKI_BASE_URL
KROKI_CLIENT_BASE_URL_ALLOWLIST=

# Graphviz WASM CDN URL（可选）
NEXT_PUBLIC_GRAPHVIZ_WASM_BASE_URL=

# 服务端口
PORT=3000
